{
    "name": "fea-viewer-frontend",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "node ./node_modules/vite/bin/vite.js",
        "build": "node ./node_modules/typescript/bin/tsc -b && node ./node_modules/vite/bin/vite.js build",
        "lint": "node ./node_modules/eslint/bin/eslint.js .",
        "preview": "node ./node_modules/vite/bin/vite.js preview",
        "test": "node ./node_modules/vitest/vitest.mjs run",
        "test:watch": "node ./node_modules/vitest/vitest.mjs",
        "test:e2e": "node ./node_modules/playwright/cli.js test",
        "typecheck": "node ./node_modules/typescript/bin/tsc -b --pretty false"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "three": "^0.170.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.45.0",
        "@testing-library/jest-dom": "^6.0.0",
        "@testing-library/react": "^16.0.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@types/three": "^0.170.0",
        "@vitejs/plugin-react": "^4.3.0",
        "eslint": "^9.39.4",
        "globals": "^15.15.0",
        "jsdom": "^25.0.0",
        "typescript": "^5.6.0",
        "typescript-eslint": "^8.57.0",
        "vite": "^6.0.0",
        "vitest": "^2.0.0"
    }
}
